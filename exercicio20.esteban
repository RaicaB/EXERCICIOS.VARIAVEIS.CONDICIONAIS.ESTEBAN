using System;
class Program
{
    static void Main()
    {
        double numero;

        Console.WriteLine("Digite um número:");
        numero = double.Parse(Console.ReadLine());

        Console.WriteLine("Dobro: " + (numero * 2));
        Console.WriteLine("Triplo: " + (numero * 3));
        Console.WriteLine("Raiz quadrada: " + Math.Sqrt(numero));
    }
}

