using System;
class Program
{
    static void Main()
    {
        int numero;

        Console.WriteLine("Digite um número inteiro:");
        numero = int.Parse(Console.ReadLine());

        Console.WriteLine("Números pares de 0 até " + numero + ":");
        for (int i = 0; i <= numero; i++)
        {
            if (i % 2 == 0)
            {
                Console.WriteLine(i);
            }
        }
    }
}
