using System;
class Program
{
    static void Main()
    {
        int numero;
        long fatorial = 1; 
        Console.WriteLine("Digite um número inteiro:");
        numero = int.Parse(Console.ReadLine());

        for (int i = 1; i <= numero; i++)
        {
            fatorial = fatorial * i;
        }

        Console.WriteLine("O fatorial de " + numero + " é: " + fatorial);
    }
}
